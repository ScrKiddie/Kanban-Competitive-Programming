{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default desktop permissions for KanbanCP",
  "windows": ["main"],
  "permissions": [
    "core:default",
    {
      "identifier": "http:default",
      "allow": [
        "https://*",
        "http://localhost:*",
        "http://127.0.0.1:*"
      ]
    },
    {
      "identifier": "opener:allow-open-url",
      "allow": [
        { "url": "https://*" },
        { "url": "http://localhost:*" },
        { "url": "http://127.0.0.1:*" }
      ]
    },
    "sql:default",
    "sql:allow-execute",
    "store:default"
  ]
}
